generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  Cashier
}

model Tenant {
  id           String        @id @db.Uuid
  name         String
  stores       Store[]
  users        User[]
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  categories   Category[]
  products     Product[]
  optionGroups OptionGroup[]
  options      Option[]
  menuVersions MenuVersion[]
  orders       Order[]
  syncLogs     SyncLog[]
  areas        Area[]
  tables       Table[]

  @@map("tenants")
}

model Store {
  id           String        @id @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  name         String
  code         String
  tableMode    Boolean       @default(false) @map("table_mode")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  users        User[]
  categories   Category[]
  products     Product[]
  optionGroups OptionGroup[]
  options      Option[]
  menuVersions MenuVersion[]
  orders       Order[]
  syncLogs     SyncLog[]
  areas        Area[]
  tables       Table[]
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, code], map: "uq_stores_tenant_code")
  @@index([tenantId], map: "idx_stores_tenant_id")
  @@map("stores")
}

model Area {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tables    Table[]
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, storeId, name], map: "uq_areas_tenant_store_name")
  @@index([tenantId, storeId], map: "idx_areas_tenant_store")
  @@map("areas")
}

model Table {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  areaId    String   @map("area_id") @db.Uuid
  name      String
  capacity  Int      @default(2)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  orders    Order[]
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, storeId, name], map: "uq_tables_tenant_store_name")
  @@index([tenantId, storeId], map: "idx_tables_tenant_store")
  @@index([areaId], map: "idx_tables_area_id")
  @@map("tables")
}

model User {
  id            String         @id @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  storeId       String         @map("store_id") @db.Uuid
  email         String
  passwordHash  String         @map("password_hash")
  role          Role
  isRevoked     Boolean        @default(false) @map("is_revoked")
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  refreshTokens RefreshToken[]
  orders        Order[]
  orderVoids    OrderVoid[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, storeId, email], map: "uq_users_tenant_store_email")
  @@index([tenantId], map: "idx_users_tenant_id")
  @@index([storeId], map: "idx_users_store_id")
  @@map("users")
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

model Category {
  id        String    @id @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  storeId   String    @map("store_id") @db.Uuid
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, storeId, name], map: "uq_categories_tenant_store_name")
  @@index([tenantId, storeId], map: "idx_categories_tenant_store")
  @@map("categories")
}

model Product {
  id                  String               @id @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  storeId             String               @map("store_id") @db.Uuid
  categoryId          String               @map("category_id") @db.Uuid
  name                String
  description         String?
  priceVnd            Int                  @map("price_vnd")
  imageUrl            String?              @map("image_url")
  sortOrder           Int                  @default(0) @map("sort_order")
  isActive            Boolean              @default(true) @map("is_active")
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store               Store                @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  category            Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  productOptionGroups ProductOptionGroup[]
  orderItems          OrderItem[]
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([categoryId], map: "idx_products_category_id")
  @@index([isActive], map: "idx_products_is_active")
  @@index([tenantId, storeId], map: "idx_products_tenant_store")
  @@map("products")
}

model OptionGroup {
  id                  String               @id @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  storeId             String               @map("store_id") @db.Uuid
  name                String
  isRequired          Boolean              @default(false) @map("is_required")
  minSelect           Int                  @default(0) @map("min_select")
  maxSelect           Int                  @default(1) @map("max_select")
  sortOrder           Int                  @default(0) @map("sort_order")
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store               Store                @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  options             Option[]
  productOptionGroups ProductOptionGroup[]
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, storeId], map: "idx_option_groups_tenant_store")
  @@map("option_groups")
}

model Option {
  id               String            @id @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  storeId          String            @map("store_id") @db.Uuid
  optionGroupId    String            @map("option_group_id") @db.Uuid
  name             String
  priceDeltaVnd    Int               @default(0) @map("price_delta_vnd")
  isDefault        Boolean           @default(false) @map("is_default")
  isActive         Boolean           @default(true) @map("is_active")
  sortOrder        Int               @default(0) @map("sort_order")
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store            Store             @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  optionGroup      OptionGroup       @relation(fields: [optionGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  orderItemOptions OrderItemOption[]
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([optionGroupId], map: "idx_options_option_group_id")
  @@index([tenantId, storeId], map: "idx_options_tenant_store")
  @@map("options")
}

model ProductOptionGroup {
  productId     String      @map("product_id") @db.Uuid
  optionGroupId String      @map("option_group_id") @db.Uuid
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([productId, optionGroupId])
  @@index([optionGroupId], map: "idx_product_option_groups_option_group_id")
  @@map("product_option_groups")
}

model MenuVersion {
  id       String   @id @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  storeId  String   @map("store_id") @db.Uuid
  version  Int      @default(1)
  bumpedAt DateTime @default(now()) @map("bumped_at") @db.Timestamptz(6)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, storeId], map: "uq_menu_versions_tenant_store")
  @@map("menu_versions")
}

enum PaymentMethod {
  Cash
  Transfer
  Card
}

model Order {
  id                String        @id @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  storeId           String        @map("store_id") @db.Uuid
  clientOrderId     String        @map("client_order_id") @db.Uuid
  orderCode         String        @map("order_code")
  deviceId          String        @map("device_id")
  cashierId         String        @map("cashier_id") @db.Uuid
  tableId           String?       @map("table_id") @db.Uuid
  tableNameSnapshot String?       @map("table_name_snapshot")
  soldAt            DateTime      @map("sold_at") @db.Timestamptz(6)
  syncedAt          DateTime      @default(now()) @map("synced_at") @db.Timestamptz(6)
  menuVersionAtSale Int           @map("menu_version_at_sale")
  discountAmount    Int           @default(0) @map("discount_amount")
  total             Int
  paymentMethod     PaymentMethod @map("payment_method")
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store             Store         @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cashier           User          @relation(fields: [cashierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  table             Table?        @relation(fields: [tableId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items             OrderItem[]
  syncLog           SyncLog?
  voids             OrderVoid[]
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, storeId, deviceId, clientOrderId], map: "uq_orders_tenant_store_device_client")
  @@index([clientOrderId], map: "idx_orders_client_order_id")
  @@index([soldAt], map: "idx_orders_sold_at")
  @@index([tenantId, storeId], map: "idx_orders_tenant_store")
  @@index([paymentMethod, soldAt], map: "idx_orders_payment_method_sold_at")
  @@index([tableId], map: "idx_orders_table_id")
  @@map("orders")
}

model OrderItem {
  id                  String            @id @db.Uuid
  orderId             String            @map("order_id") @db.Uuid
  productId           String            @map("product_id") @db.Uuid
  productNameSnapshot String            @map("product_name_snapshot")
  unitPriceSnapshot   Int               @map("unit_price_snapshot")
  quantity            Int
  note                String?
  lineTotal           Int               @map("line_total")
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product             Product           @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  options             OrderItemOption[]
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model OrderItemOption {
  id                 String    @id @db.Uuid
  orderItemId        String    @map("order_item_id") @db.Uuid
  optionId           String    @map("option_id") @db.Uuid
  labelSnapshot      String    @map("label_snapshot")
  priceDeltaSnapshot Int       @map("price_delta_snapshot")
  orderItem          OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  option             Option    @relation(fields: [optionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orderItemId], map: "idx_order_item_options_order_item_id")
  @@map("order_item_options")
}

model SyncLog {
  id            String   @id @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  storeId       String   @map("store_id") @db.Uuid
  deviceId      String   @map("device_id")
  clientOrderId String   @map("client_order_id") @db.Uuid
  orderId       String   @unique(map: "uq_sync_log_order_id") @map("order_id") @db.Uuid
  firstSyncedAt DateTime @default(now()) @map("first_synced_at") @db.Timestamptz(6)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, storeId, deviceId, clientOrderId], map: "uq_sync_log_tenant_store_device_client")
  @@index([tenantId, storeId], map: "idx_sync_log_tenant_store")
  @@map("sync_log")
}

model OrderVoid {
  id       String   @id @db.Uuid
  orderId  String   @map("order_id") @db.Uuid
  voidedBy String   @map("voided_by") @db.Uuid
  reason   String
  voidedAt DateTime @default(now()) @map("voided_at") @db.Timestamptz(6)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user     User     @relation(fields: [voidedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId], map: "idx_order_voids_order_id")
  @@map("order_voids")
}
